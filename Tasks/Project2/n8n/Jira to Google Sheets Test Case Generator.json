    {
      "parameters": {
        "jsCode": "// Extract test cases from AI output\nconst testCases = $input.first().json.output.testCases || [];\n\n// Format each test case for Google Sheets\nconst formattedTestCases = testCases.map(tc => ({\n  json: {\n    'Test Case Id': tc.id || '',\n    'Summary/Title': tc.title || '',\n    'Preconditions': tc.preconditions || '',\n    'Test Steps': tc.steps || '',\n    'Expected result': tc.expectedResult || '',\n    'Actual result': '',\n    'Status': 'Not Executed',\n    'Execution date': '',\n    'Comments': `Priority: ${tc.priority || 'Medium'} | Type: ${tc.type || 'Functional'}`\n  }\n}));\n\nreturn formattedTestCases;"
      },
