<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- thread-count default mirrors ConfigManager's default (4); override at
     runtime with -Dthread.count is read by ApiClient/ConfigManager for
     application-level concerns, this attribute controls TestNG's own pool. -->
<suite name="ApiTestFrameworkSuite" parallel="methods" thread-count="4" verbose="1">

    <listeners>
        <listener class-name="com.framework.listeners.RetryListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Ping Tests">
        <classes>
            <class name="com.tests.ping.HealthCheckTest"/>
        </classes>
    </test>

    <test name="Auth Tests">
        <classes>
            <class name="com.tests.auth.CreateAuthTokenTest"/>
        </classes>
    </test>

    <test name="Booking Tests">
        <classes>
            <class name="com.tests.booking.CreateBookingTest"/>
            <class name="com.tests.booking.GetBookingTest"/>
            <class name="com.tests.booking.UpdateBookingTest"/>
            <class name="com.tests.booking.PartialUpdateBookingTest"/>
            <class name="com.tests.booking.DeleteBookingTest"/>
        </classes>
    </test>

</suite>
